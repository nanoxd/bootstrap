#!/bin/bash

is_apple_silicon() {
  [[ "$(arch)" == "arm64" ]] || return 1
}

fancy_echo() {
  local fmt="$1"; shift

  printf "\n$fmt\n" "$@"
}

wait_for_input() {
  fancy_echo "$1"
  read -n 1
}

append_to_zshrc() {
  local text="$1" zshrc
  local skip_new_line="${2:-0}"

  if [ -w "$HOME/.zshrc.local" ]; then
    zshrc="$HOME/.zshrc.local"
  else
    zshrc="$HOME/.zshrc"
  fi

  if ! grep -Fqs "$text" "$zshrc"; then
    if [ "$skip_new_line" -eq 1 ]; then
      printf "%s\n" "$text" >> "$zshrc"
    else
      printf "\n%s\n" "$text" >> "$zshrc"
    fi
  fi
}

trap 'ret=$?; test $ret -ne 0 && printf "failed\n\n" >&2; exit $ret' EXIT

set -e

if [ ! -d "$HOME/.bin/" ]; then
  mkdir "$HOME/.bin"
fi

if [ ! -f "$HOME/.zshrc" ]; then
  touch "$HOME/.zshrc"
fi

append_to_zshrc 'export PATH="$HOME/.bin:$PATH"'

update_shell() {
  local shell_path;
  shell_path="$(which zsh)"

  fancy_echo "Changing your shell to zsh ..."
  if ! grep "$shell_path" /etc/shells > /dev/null 2>&1 ; then
    fancy_echo "Adding '$shell_path' to /etc/shells"
    sudo sh -c "echo $shell_path >> /etc/shells"
  fi
  chsh -s "$shell_path"
}

homebrew_zsh() {
  if is_apple_silicon; then
    echo "/opt/homebrew/bin/zsh"
  else
    echo "/usr/local/bin/zsh"
  fi
}

# Update shell to Homebrew zsh if available, otherwise ensure zsh is set
if [ -x "$(homebrew_zsh)" ]; then
  if [ "$SHELL" != "$(homebrew_zsh)" ]; then
    update_shell
  fi
elif [ "${SHELL##*/}" != "zsh" ]; then
  update_shell
fi

generate_ssh_key() {
  ssh-keygen -a 100 -t ed25519
  ssh-add ~/.ssh/id_ed25519
  pbcopy < ~/.ssh/id_ed25519.pub
}

if ! command -v brew >/dev/null; then
  # Empty out dock
  defaults write com.apple.dock persistent-apps -array
  fancy_echo "Installing Homebrew ..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    append_to_zshrc '# recommended by brew doctor'
    if is_apple_silicon; then
        append_to_zshrc 'export PATH="/opt/homebrew/bin:$PATH"' 1
        export PATH="/opt/homebrew/bin:$PATH"
      else
        append_to_zshrc 'export PATH="/usr/local/bin:$PATH"' 1
        export PATH="/usr/local/bin:$PATH"
    fi
else
  fancy_echo "Homebrew already installed. Skipping ..."
fi

fancy_echo "Updating Homebrew formulas ..."
brew update

make brew

if ! cat /etc/shells | grep -Fq fish; then
  fancy_echo "Adding fish to /etc/shells"

  echo "$(which fish)" | sudo tee -a /etc/shells
fi

fancy_echo "Checking for SSH key, generating one if it doesn't exist ..."
  if [[ ! -f ~/.ssh/id_ed25519.pub ]]; then
    generate_ssh_key
    wait_for_input "Please add the SSH key to GitHub"
  fi

fancy_echo "Checking for GPG Key, generating one if it doesn't exist ..."
  if [[ ! -f ~/.gnupg/pubring.kbx ]]; then
    fancy_echo "Please enter your name for the GPG key:"
    read gpg_name
    fancy_echo "Please enter your email for the GPG key:"
    read gpg_email

    # Generate GPG key non-interactively
    gpg --batch --generate-key <<EOF
%no-protection
Key-Type: EdDSA
Key-Curve: ed25519
Key-Usage: sign
Subkey-Type: ECDH
Subkey-Curve: cv25519
Subkey-Usage: encrypt
Name-Real: $gpg_name
Name-Email: $gpg_email
Expire-Date: 0
EOF

    gpg_pub_key="$(gpg --list-keys --keyid-format LONG | grep pub | awk '{print $2}' | awk -F '/' '{print $2}' | xargs)"
    local_gitconfig="$HOME/.gitconfig.local"

    git config --file="$local_gitconfig" user.signingkey "$gpg_pub_key"
    gpg --armor --export "$gpg_email" | pbcopy
    git config --file="$local_gitconfig" commit.gpgsign true
    wait_for_input "Please add the GPG key to GitHub (copied to clipboard)"
  fi

fancy_echo "Installing Rust"
if [ ! -e "$HOME/.cargo/bin" ]; then
  curl https://sh.rustup.rs -sSf | sh
  append_to_zshrc 'export PATH="$HOME/.cargo/bin:$PATH"' 1

  source $HOME/.cargo/env
  rustup install stable
  rustup default stable
  rustup component add rust-analyzer rustfmt clippy
fi

make rust

if [ ! -d "$HOME/.dotfiles/" ]; then
  cargo install --git https://github.com/ubnt-intrepid/dot.git
  dot init nanoxd/dotfiles
fi

fancy_echo "Symlinking diff-highlight from brew git ..."
diff_hl="$(brew --prefix git)/share/git-core/contrib/diff-highlight/diff-highlight"
if [ -x "$diff_hl" ] && [ ! -e "$HOME/.bin/diff-highlight" ]; then
  ln -sf "$diff_hl" "$HOME/.bin/diff-highlight"
fi

fancy_echo "Installing pynvim ..."
"$(brew --prefix python3)/libexec/bin/python" -m pip install --upgrade pynvim

if ! command -v mise >/dev/null; then
  fancy_echo "Installing mise ..."
  curl -fsSL https://mise.run | sh
else
  fancy_echo "Skipping mise (already installed)"
fi
