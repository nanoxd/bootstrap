#!/usr/bin/env sh

fancy_echo() {
  local fmt="$1"; shift

  printf "\n$fmt\n" "$@"
}

TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

download_and_run() {
    local name=$1
    local url=$2
    local shell=${3:-sh}
    local script_path="$TEMP_DIR/${name}_install.sh"

    fancy_echo "Downloading $name installer..."
    if ! curl -fsSL "$url" -o "$script_path"; then
        fancy_echo "Failed to download $name installer"
        return 1
    fi

    fancy_echo "Installing $name..."
    $shell "$script_path"
}

install_binary() {
    local command=$1
    local url=$2
    local shell=${3:-sh}

    if ! command -v "$command" >/dev/null; then
        download_and_run "$command" "$url" "$shell"
    else
        fancy_echo "Skipping $command (already installed)"
    fi
}

install_binary "mise" "https://mise.run"
install_binary "bun" "https://bun.sh/install" "bash"
install_binary "deno" "https://deno.land/install.sh"
